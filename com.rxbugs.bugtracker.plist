<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.rxbugs.bugtracker</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Update this path to point to your venv's python binary -->
    <string>/Users/stevenross/Developer/RxBugs/.venv/bin/python</string>
    <string>/Users/stevenross/Developer/RxBugs/app.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/stevenross/Developer/RxBugs</string>

  <key>RunAtLoad</key>
