# Long-lived human UI token.  Required — server refuses to start without it.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BUGTRACKER_TOKEN=your-token-here

# SQLAlchemy connection URL.  Defaults to SQLite in the project directory.
# DATABASE_URL=sqlite:////absolute/path/to/bugtracker.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host/dbname
# DATABASE_URL=mysql+pymysql://user:pass@host/dbname

# Flask host / port (defaults shown)
# BUGTRACKER_HOST=0.0.0.0
# BUGTRACKER_PORT=5000
